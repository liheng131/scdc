# 基础运行配置
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=supersecretkey

# JWT 鉴权与安全配置
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# PostgreSQL 数据库配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=scdc_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DSN=postgresql+psycopg2://postgres:postgres@localhost:5432/scdc_db

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# 邮件与异步通知配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=2734818986@qq.com
SMTP_PASSWORD=llvbheyusdctdcci
SMTP_FROM_EMAIL=2734818986@qq.com

# 外部组件与模型服务配置 (预留)
# ⚠️ 启动 backend 模式决定此处值：
#   1) uvicorn app.main:app --reload (host 上)  → http://localhost:11434
#   2) docker compose up -d backend (容器内)    → http://ollama:11434
# ⚠️ 同步检查 DB 中 ai_model_configs (embedding 行) 的 base_url 必须与模式一致！
#   否则会复现 "Server disconnected" 错误。
#
# OLLAMA_BASE_URL 含义：
#   - 本地 uvicorn 模式（uvicorn app.main:app --reload）：填 http://localhost:11434，要求本机已起 ollama serve
#   - 完整 docker compose 模式：填 http://ollama:11434（Docker 网络名），由 docker-compose.yml 注入
#   - 混部模式（infra 容器 + 本地后端）：填 http://localhost:11434 + 本机 ollama serve，或 http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=qwen2.5:latest
EMBEDDING_MODEL=nomic-embed-text
SEARXNG_URL=http://localhost:8080
MILVUS_URL=http://localhost:19530
OPENSEARCH_URL=http://localhost:9200
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=scdc-storage

# AnySearch 搜索引擎
# 通过 https://api.anysearch.com/v1/search 发起搜索请求
ANYSEARCH_API_KEY=as_sk_570631acc467a32b822b64646948acc8
ANYSEARCH_BASE_URL=https://api.anysearch.com
ANYSEARCH_DEFAULT_MAX_RESULTS=10
ANYSEARCH_TIMEOUT=10
